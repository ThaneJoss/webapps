{
  "name": "waas-showcase",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "build": "npm run typecheck && npm run build:web",
    "build:web": "vite build && node scripts/inline-critical-css.mjs",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@unocss/preset-uno": "^66.5.4",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^29.0.2",
    "split-vendor-chunk-plugin": "^7.0.0",
    "typescript": "^5.9.3",
    "unocss": "^66.5.4",
    "vite": "^7.1.10",
    "vite-plugin-sitemap": "^0.8.2",
    "vitest": "^4.1.3",
    "vue-tsc": "^3.1.1"
  }
}

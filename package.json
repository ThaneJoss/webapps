{
  "name": "waas-showcase",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "tsx watch api/src/dev.ts",
    "build": "npm run typecheck && npm run build:web && npm run build:api",
    "build:web": "vite build && node scripts/inline-critical-css.mjs",
    "build:api": "tsc -p api/tsconfig.json",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p api/tsconfig.json",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.4",
    "@iconify/vue": "^5.0.0",
    "hono": "^4.10.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@unocss/preset-uno": "^66.5.4",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "split-vendor-chunk-plugin": "^7.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "unocss": "^66.5.4",
    "vite": "^7.1.10",
    "vite-plugin-sitemap": "^0.8.2",
    "vitest": "^4.1.3",
    "vue-tsc": "^3.1.1"
  }
}
